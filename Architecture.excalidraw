    {
      "id": "q99chj755nt",
      "type": "text",
      "x": 798,
      "y": 204,
      "width": 404,
      "height": 173,
      "strokeColor": "#6741d9",
      "backgroundColor": "transparent",
      "text": "🧠 总调度 Orchestrator Agent\n(顶级 · 常驻 MQTT 进程)\n\nSub: orchestrator/command\nLLM 意图识别 → 任务拆解\nPub: agent/.../task/assign × N\nSub: +/task/result  汇总子任务\nSub: +/task/failed  通知真人",
      "fontSize": 13,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "7hzioykl1cr",
      "lineHeight": 1.25,
