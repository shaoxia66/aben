    {
      "id": "2qp89uzfk8t",
      "type": "text",
      "x": 448,
      "y": 204,
      "width": 314,
      "height": 173,
      "strokeColor": "#2b8a3e",
      "backgroundColor": "transparent",
      "text": "⚙️ API 服务 (RBAC·JWT)\n\nPOST /agents/:id/trigger  [F-00c]\nPOST /agents/trigger  (全局触发)\nPOST /human-requests/:id/respond\nGET  /api-tools\nPOST /api-tools/:id/test\nGET  /tasks/:taskId/status\nPOST /agents/:id/trigger-keys",
      "fontSize": 12,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "74frhocn9jr",
      "lineHeight": 1.25,
